{
  "AllowedHosts": "*",
  "AiProvider": {
    "Provider": "Mock"
  },
  "AzureOpenAI": {
    "Endpoint": "<azure-openai-endpoint>",
    "ApiKey": "<azure-openai-api-key-from-key-vault>",
    "DeploymentName": "<azure-openai-deployment-name>",
    "TimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
